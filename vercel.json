{
  "version": 2,
  "name": "bwc-telemetry",
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "VITE_APPWRITE_PROJECT": "@appwrite_project_id",
    "VITE_APPWRITE_ENDPOINT": "@appwrite_endpoint"
  }
}